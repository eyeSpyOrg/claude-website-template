# ─────────────────────────────────────────────────────────────
# Environment variables — Phase 2 integrations
# Copy to .env locally (gitignored). In production these live in
# GitHub Actions secrets and/or AWS Amplify environment variables.
# NO value in this file, ever. See INTEGRATIONS.md.
# ─────────────────────────────────────────────────────────────

# Stripe — Pattern C (Checkout Sessions / webhooks) only.
# Payment Links need no keys at all.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Printify — used at BUILD TIME only (catalog fetch in CI).
PRINTIFY_API_TOKEN=
PRINTIFY_SHOP_ID=

# HubSpot — only if a server-side Private App is ever added.
# The Forms Submission API used by HubSpotForm.astro needs no token.
HUBSPOT_PRIVATE_APP_TOKEN=
