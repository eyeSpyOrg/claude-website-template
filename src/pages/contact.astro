---
/**
 * Contact — NAP renders only from site.js (never drifts from footer
 * or Organization schema). Inquiry form arrives with HubSpot in
 * Phase 2 via HubSpotForm.astro — never the embedded widget.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { SITE } from '../config/site.js';

// Non-breaking hyphen (U+2011) so the phone number never wraps mid-line
const telDisplay = '(844) 222‑8848';
---

<BaseLayout
  title="Contact"
  description="Contact The Fashion PAWty team at team@eyespy.org or (844) 222-8848 with questions about tickets, sponsorship, or accessibility — we greet everyone with a hug or a handshake."
>
  <div class="container">
    <Breadcrumbs
      items={[{ name: 'Home', href: '/' }, { name: 'Contact', href: '/contact/' }]}
    />
    <h1>Say Hello</h1>
    <div class="prose">
      <p>
        We greet everyone with a hug or a handshake — and email works too. Have
        a question about tickets, sponsorship, or bringing your pup? We'd love
        to hear from you.
      </p>

      <h2>How can you reach us?</h2>
      <ul>
        <li>Email: <a href={`mailto:${SITE.email}`}>{SITE.email}</a></li>
        <li>Phone: <a href={`tel:${SITE.telephone}`}>{telDisplay}</a></li>
      </ul>

      <h2>Where is the PAWty?</h2>
      <p>
        {SITE.event.venueName}, {SITE.address.streetAddress},
        {SITE.address.addressLocality}, {SITE.address.addressRegion}
        {SITE.address.postalCode} — see the <a href="/venue/">Venue page</a> for
        parking and accessibility details.
      </p>

      {/* TODO: inquiry form (name, email, message → team@eyespy.org) lands in
          Phase 2 with the HubSpot portal + form GUID, rendered through
          HubSpotForm.astro (see INTEGRATIONS.md §2). */}
    </div>
  </div>
</BaseLayout>
