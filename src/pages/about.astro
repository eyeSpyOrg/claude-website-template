---
/** Interior page template: breadcrumbs + one h1 + prose measure. */
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
---

<BaseLayout
  title="About"
  description="Replace: 145–160 character description with the primary keyword in the first 50 characters."
>
  <div class="container">
    <Breadcrumbs items={[{ name: 'Home', href: '/' }, { name: 'About', href: '/about/' }]} />
    <h1>About</h1>
    <div class="prose">
      <p>Interior page starter. Keep headings in order (h1 → h2 → h3, never skip down).</p>
      <h2>Section heading</h2>
      <p>Body copy at a 70ch max measure for readability.</p>
    </div>
  </div>
</BaseLayout>
