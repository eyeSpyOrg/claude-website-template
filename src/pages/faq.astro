---
/**
 * FAQ page template. Answers must be self-contained (make sense out of
 * context) — answer engines quote them directly. The FAQ component
 * generates the visible accordion AND FAQPage schema from the same array.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import FAQ from '../components/FAQ.astro';
import { SITE } from '../config/site.js';

const faqs = [
  {
    question: `What does ${SITE.name} do?`,
    answer:
      'Replace with a direct, self-contained 1–3 sentence answer. Lead with the definition — answer engines quote the first sentence.',
  },
  {
    question: 'How can I get involved?',
    answer:
      'Replace with a concrete answer naming the actual ways to participate (volunteer, donate, subscribe) and where to start.',
  },
  {
    question: 'How do I contact you?',
    answer: `Replace with the fastest contact route and response time, e.g. email ${SITE.email} — we respond within two business days.`,
  },
];
---

<BaseLayout
  title="FAQ"
  description="Replace: 145–160 character description promising direct answers to the most common questions about the organization."
>
  <div class="container">
    <Breadcrumbs items={[{ name: 'Home', href: '/' }, { name: 'FAQ', href: '/faq/' }]} />
    <h1>Frequently asked questions</h1>
    <p class="prose">
      Replace: one sentence framing what these questions cover and where to ask
      anything not answered here.
    </p>
    <FAQ faqs={faqs} heading="General questions" />
  </div>
</BaseLayout>
