---
/**
 * Merch — links out to the Printify shop (shop.thefashionpawty.com).
 * No Product schema on-site; the shop subdomain carries its own markup.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
---

<BaseLayout
  title="PAWty Merch"
  description="Shop Fashion PAWty merch at shop.thefashionpawty.com — wear the cause, because every purchase helps support the blind and low vision community in Jacksonville."
>
  <div class="container">
    <Breadcrumbs items={[{ name: 'Home', href: '/' }, { name: 'Merch', href: '/merch/' }]} />
    <h1>PAWty Merch</h1>
    <div class="prose">
      <p>
        Wear the cause. Our merch shop is stocked with Fashion PAWty gear —
        every purchase helps support the blind and low vision community.
      </p>
      <p>
        <a class="btn btn--primary" href="https://shop.thefashionpawty.com" rel="noopener">
          Shop the Collection
        </a>
      </p>
      <p>
        We're still adding items — check back as the collection grows before
        September 26.
      </p>
    </div>
  </div>
</BaseLayout>
