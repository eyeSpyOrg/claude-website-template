---
/**
 * Venue — Happy Brew: address, parking, accessibility, map link.
 * Event schema included.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ImagePlaceholder from '../components/ImagePlaceholder.astro';
import EventSchema from '../components/schema/EventSchema.astro';
import { SITE } from '../config/site.js';

const mapsUrl =
  'https://www.google.com/maps/search/?api=1&query=Happy+Brew+3200+Hendricks+Ave+Jacksonville+FL+32207';
---

<BaseLayout
  title="Venue — Happy Brew, Jacksonville"
  description="The Fashion PAWty happens at Happy Brew, 3200 Hendricks Ave, Jacksonville, FL 32207 — a fully accessible venue with parking in the church lot next door on Hendricks Avenue."
>
  <section class="band band--teal band--tight">
    <div class="container">
      <Breadcrumbs items={[{ name: 'Home', href: '/' }, { name: 'Venue', href: '/venue/' }]} />
      <div class="split">
        <div class="split__text">
          <p class="eyebrow">Right on Hendricks Ave</p>
          <h1>Where the PAWty Happens</h1>
          <p class="venue-address">
            <strong>Happy Brew</strong><br />
            3200 Hendricks Ave, Jacksonville, FL 32207
          </p>
          <p class="prose">
            The Fashion PAWty takes over Happy Brew — a welcoming Jacksonville
            spot right on Hendricks Avenue. Come thirsty, come with your best
            outfit on, and come ready to celebrate.
          </p>
          <p>
            <a class="btn btn--primary btn--lg" href={mapsUrl} rel="noopener">
              Get directions to Happy Brew
            </a>
          </p>
        </div>
        {/* TODO: optionally swap this placeholder for an accessible embedded
            map once the team picks an embed approach (keyboard-friendly,
            consent-aware). */}
        <ImagePlaceholder label="Map / photo of Happy Brew on Hendricks Ave" policy="ai" ratio="4 / 3" icon="🗺️" />
      </div>
    </div>
  </section>

  <section class="band">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Plan Your Visit</p>
        <h2>Getting There and Good to Know</h2>
      </div>
      <div class="grid grid--3">
        <div class="card card--accent stack">
          <span class="info__icon" aria-hidden="true">🅿️</span>
          <h3>Where do I park?</h3>
          <p>Park in the church lot next door on Hendricks Avenue, with overflow parking behind the church.</p>
        </div>
        <div class="card card--accent stack">
          <span class="info__icon" aria-hidden="true">♿</span>
          <h3>Is the venue accessible?</h3>
          <p>
            The entire venue is accessible. Questions about your visit? Email
            <a href={`mailto:${SITE.email}`}>{SITE.email}</a> and we'll make sure
            you have what you need.
          </p>
        </div>
        <div class="card card--accent stack">
          <span class="info__icon" aria-hidden="true">🚗</span>
          <h3>Rideshare</h3>
          {/* TODO: rideshare drop-off note — optional, confirm with the team. */}
          <p>Dropping off by rideshare? Use the Hendricks Avenue entrance. We'll confirm a dedicated drop-off spot closer to the event.</p>
        </div>
      </div>
    </div>
  </section>

  <EventSchema />
</BaseLayout>

<style>
  .split { display: grid; gap: var(--space-l); align-items: center; }
  .split__text > * + * { margin-top: var(--space-s); }
  @media (min-width: 52rem) { .split { grid-template-columns: 1.1fr 0.9fr; gap: var(--space-xl); } }
  .venue-address { font-size: var(--step-1); }
  .info__icon { font-size: 2rem; line-height: 1; }
</style>
