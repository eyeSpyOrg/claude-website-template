---
/**
 * Sponsors — the six real tiers from BRAND.md § 2.9 as cards.
 * Photo Booth is claimed (Lions Club of Jacksonville Beach) and
 * renders as a thank-you, NOT purchasable.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const pawtyTiers = [
  {
    name: 'Best in Show',
    price: '$500',
    pkg: 'Gold',
    blurb:
      "Our top billing. You're the main PAW-ty sponsor on every print and digital asset, plus the Runway (Orange Carpet) sponsor — your name on the star of the show.",
  },
  {
    name: 'Top Dog',
    price: '$200',
    pkg: 'Silver',
    blurb:
      'Your choice of one signature area: the Music Stage, the Mock-Tail Bar, or the Chow-Down Station.',
  },
  {
    name: 'Bark-star',
    price: '$100',
    pkg: 'Bronze',
    blurb:
      'Your choice of one station: DJ PAWty, Bone Up Station, Photo Booth, Merch Shop, or Sensory Games.',
  },
];
const vendorTiers = [
  {
    name: 'Dog House',
    price: '$200',
    pkg: 'Gold',
    blurb:
      'Bring your own tent and set up on the back lawn to engage with all the PAWty people.',
  },
  {
    name: 'PAW-parazzi',
    price: '$100',
    pkg: 'Silver',
    blurb: 'A shout-out on our social media and emails.',
  },
  {
    name: 'PAWty Animal',
    price: '$50',
    pkg: 'Bronze',
    blurb: 'A PAWty Pass ticket plus your own tailgate chair.',
  },
];
---

<BaseLayout
  title="Sponsor the PAWty"
  description="Sponsor The Fashion PAWty in Jacksonville — six tiers from $50 to $500 with signage, social placement, and VIP seating, all helping us raise $25,000 for the blind and low vision community."
>
  <div class="container">
    <Breadcrumbs items={[{ name: 'Home', href: '/' }, { name: 'Sponsors', href: '/sponsors/' }]} />
    <h1>Sponsor the PAWty</h1>
    <p class="prose">
      Every great party has people who make it happen. Pick your tier, put your
      name on the fun, and help us reach our $25,000 goal for the blind and low
      vision community. Every sponsorship includes a welcome goodie bag, station
      signage, social media and email placement, and VIP seating for two.
    </p>

    <h2>PAW-ty Sponsor Tiers</h2>
    <ul class="tiers">
      {pawtyTiers.map((t) => (
        <li class="tier">
          <h3>{t.name}</h3>
          <p class="tier__price">{t.price} <span class="tier__pkg">({t.pkg})</span></p>
          <p>{t.blurb}</p>
          <p>
            {/* TODO: replace with real Stripe Payment Link */}
            <a class="btn btn--primary" href="https://stripe.com">Sponsor — {t.name} {t.price}</a>
          </p>
        </li>
      ))}
    </ul>

    <h2>Vendor Sponsor Tiers</h2>
    <ul class="tiers">
      {vendorTiers.map((t) => (
        <li class="tier">
          <h3>{t.name}</h3>
          <p class="tier__price">{t.price} <span class="tier__pkg">({t.pkg})</span></p>
          <p>{t.blurb}</p>
          <p>
            {/* TODO: replace with real Stripe Payment Link */}
            <a class="btn btn--primary" href="https://stripe.com">Sponsor — {t.name} {t.price}</a>
          </p>
        </li>
      ))}
    </ul>

    <p class="prose includes">
      <strong>Every sponsorship includes:</strong> welcome goodie bag · station
      signage · social media &amp; email placement · VIP seating for 2.
    </p>

    <h2>A big thank-you to our claimed sponsor</h2>
    <div class="tier tier--claimed">
      <h3>Photo Booth 📸</h3>
      <p>
        Proudly sponsored by the <strong>Lions Club of Jacksonville Beach</strong>.
        Thank you for helping the PAWty shine!
      </p>
    </div>
  </div>
</BaseLayout>

<style>
  .tiers {
    list-style: none;
    margin: 0 0 2rem;
    padding: 0;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fit, minmax(17rem, 1fr));
  }
  .tier {
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    border-top: 6px solid var(--color-gold-highlight);
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
  }
  .tier h3 { margin-top: 0; }
  .tier__price { font-size: var(--step-1); font-weight: 700; margin: 0.25rem 0; }
  .tier__pkg { font-size: var(--step-0); font-weight: 600; color: var(--color-text-muted); }
  .tier--claimed { max-width: 34rem; }
  .includes { margin-block: 1rem 2.5rem; }
</style>
