---
/**
 * Homepage template. Demonstrates the required patterns:
 * exactly one h1, logical heading order, answer-first copy (AEO),
 * FAQ block with schema, breadcrumbless (home doesn't need them).
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQ from '../components/FAQ.astro';
import { SITE } from '../config/site.js';

const faqs = [
  {
    question: `What is ${SITE.name}?`,
    answer:
      'Replace with a direct, 1–3 sentence answer. Answer engines quote the first sentence, so lead with the definition.',
  },
  {
    question: 'How do I get started?',
    answer: 'Replace with a concrete, self-contained answer that makes sense out of context.',
  },
];
---

<BaseLayout title="Home" description={SITE.description}>
  <div class="container">
    <!-- HERO: answer-first. The h1 + first paragraph should tell a
         human AND an answer engine exactly what this site is. -->
    <h1>{SITE.name}</h1>
    <p class="prose lead">
      One clear sentence stating what this organization does, for whom, and where.
      This paragraph is what AI Overviews and answer engines will quote.
    </p>
    <p>
      <a class="btn btn--primary" href="/about/">Learn more about us</a>
    </p>

    <FAQ faqs={faqs} />
  </div>
</BaseLayout>

<style>
  .lead { font-size: var(--step-1); color: var(--color-text-muted); }
  .btn--primary {
    display: inline-flex;
    align-items: center;
    background: var(--color-accent);
    color: #ffffff;
    text-decoration: none;
    font-weight: 700;
    padding: 0.75rem 1.5rem;
    border-radius: 10px;
  }
  .btn--primary:hover { background: var(--color-accent-hover); color: #ffffff; }
  :global(html[data-a11y-contrast='high']) .btn--primary { color: #000000; }
</style>
