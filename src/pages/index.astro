---
/**
 * Homepage — hero on the pattern band, answer-first overview,
 * quick facts, sizzle-reel placeholder, goal, FAQ (with schema),
 * Event schema. Copy from PAGE_COPY.md.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQ from '../components/FAQ.astro';
import EventSchema from '../components/schema/EventSchema.astro';
import { SITE } from '../config/site.js';

const faqs = [
  {
    question: 'What is The Fashion PAWty?',
    answer:
      'The Fashion PAWty is a doggie fashion show and community celebration — "A Navigation Celebration" — hosted by the Eye Spy Foundation in Jacksonville, Florida. Dogs strut the orange carpet while the community enjoys mocktails, food, games, and music, all to support the blind and low vision community and Leader Dogs for the Blind.',
  },
  {
    question: 'When and where is The Fashion PAWty?',
    answer:
      'Saturday, September 26, 2026, from 4 to 7 PM at Happy Brew, 3200 Hendricks Ave, Jacksonville, FL 32207.',
  },
  {
    question: 'How much are tickets and what is included?',
    answer:
      'Tickets are $30 and include entry to the show, food, and mocktails.',
  },
  {
    question: 'Who does the event benefit?',
    answer:
      'The Eye Spy Foundation and Leader Dogs for the Blind. Eye Spy is also sponsoring one Leader Dogs puppy this year.',
  },
];
---

<BaseLayout title="Home" description={SITE.description}>
  <!-- HERO -->
  <div class="band--hero">
    <div class="container hero">
      <h1>Strut for a More Accessible World</h1>
      <p class="prose lead">
        Join The Fashion PAWty on Saturday, September 26 at Happy Brew for a
        doggie fashion show down the orange carpet — plus mocktails, games, and
        music, all benefiting the blind and low vision community.
      </p>
      <p class="hero__ctas">
        <a class="btn btn--primary" href="/tickets/">Get Tickets — $30</a>
        <a class="btn btn--secondary" href="/sponsors/">Become a Sponsor</a>
      </p>
    </div>
  </div>

  <hr class="carpet-divider" aria-hidden="true" />

  <div class="container">
    <!-- Quick facts -->
    <section aria-labelledby="facts-heading">
      <h2 id="facts-heading" class="sr-only">Event at a glance</h2>
      <ul class="facts">
        <li>📅 Saturday, September 26, 2026 · 4–7 PM</li>
        <li>📍 Happy Brew, Jacksonville</li>
        <li>🎟️ $30 (show + food + mocktails)</li>
        <li>🐾 Benefiting Eye Spy Foundation &amp; Leader Dogs for the Blind</li>
      </ul>
    </section>

    <!-- Answer-first overview -->
    <section aria-labelledby="about-heading">
      <h2 id="about-heading">A Runway with Real Impact</h2>
      <p class="prose">
        The Fashion PAWty is a Navigation Celebration hosted by the Eye Spy
        Foundation, supporting the blind and low vision community and Leader
        Dogs for the Blind — helping people navigate the world with confidence,
        online and on the street. Dogs strut the orange carpet, the community
        comes together, and tickets are $30 including the show, food, and
        mocktails.
      </p>
    </section>

    <!-- Sizzle reel — placeholder until the YouTube URL exists -->
    <section aria-labelledby="video-heading">
      <h2 id="video-heading">Take a Look at the PAWty</h2>
      <!--
        TODO: replace this placeholder with the real YouTube sizzle reel.
        Drop the accessible embed in (privacy-enhanced domain, captions on,
        no autoplay with sound):
        <div class="video-embed">
          <iframe
            src="https://www.youtube-nocookie.com/embed/VIDEO_ID"
            title="The Fashion PAWty sizzle reel"
            loading="lazy"
            allowfullscreen></iframe>
        </div>
        TODO: add VideoObject schema once the real YouTube URL exists
        (name, description, thumbnailUrl, uploadDate, embedUrl).
      -->
      <p class="video-placeholder prose">
        Our sizzle reel is coming soon — check back for a first look at the
        orange carpet.
      </p>
    </section>
  </div>

  <!-- Goal band -->
  <div class="band--dark goal-band">
    <div class="container">
      <h2>Help Us Reach $25,000</h2>
      <p class="prose">
        Together we're raising $25,000 to help the blind and low vision
        community navigate the resources that make for a better low vision
        lifestyle. Every ticket, sponsor, and wagging tail gets us closer.
      </p>
      <p>
        <a class="btn btn--gold-band" href="/sponsors/">See sponsorship tiers</a>
      </p>
    </div>
  </div>

  <div class="container">
    <FAQ faqs={faqs} heading="Frequently asked questions" />
    <p class="prose">
      More questions? Visit the <a href="/faq/">full FAQ page</a> or email
      <a href={`mailto:${SITE.email}`}>{SITE.email}</a>.
    </p>
  </div>

  <EventSchema />
</BaseLayout>

<style>
  .hero { padding-block: 4rem; }
  .lead { font-size: var(--step-1); color: var(--color-text-muted); }
  .hero__ctas { display: flex; gap: 1rem; flex-wrap: wrap; }
  .btn--gold-band { background: #ffffff; color: var(--color-accent-hover); }
  .btn--gold-band:hover { background: var(--color-bg); color: var(--color-accent-hover); }
  :global(html[data-a11y-contrast='high']) .btn--gold-band { color: #000000; background: var(--color-accent); }

  .facts {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    font-weight: 600;
  }
  .facts li {
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    border-radius: 10px;
    padding: 1rem 1.25rem;
  }
  section { margin-block: 2.5rem; }
  .video-placeholder {
    border: 2px dashed var(--color-border);
    border-radius: 10px;
    padding: 2.5rem 1.5rem;
    background: var(--color-surface);
  }
  .goal-band { padding-block: 1rem; }
</style>
