---
/**
 * Universal Header — semantic landmark, keyboard-first nav,
 * accessible mobile disclosure menu (WAI-ARIA APG pattern),
 * aria-current on the active page.
 * Nav items come from src/config/site.js.
 */
import { SITE } from '../config/site.js';

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header class="site-header">
  <div class="site-header__inner">
    <a href="/" class="site-header__brand">
      <img
        class="site-header__logo site-header__logo--color"
        src="/logo.png"
        alt={`${SITE.name} — home`}
        width="134"
        height="48"
      />
      <img
        class="site-header__logo site-header__logo--hc"
        src="/logo-high-contrast.png"
        alt={`${SITE.name} — home`}
        width="134"
        height="48"
      />
    </a>

    <nav id="primary-nav" class="site-header__nav" aria-label="Primary" data-menu>
      <ul>
        {SITE.nav.map((item) => (
          <li>
            <a
              href={item.href}
              aria-current={isActive(item.href) ? 'page' : undefined}
              rel={item.external ? 'noopener' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="site-header__actions">
      <a class="btn btn--secondary site-header__buy" href={SITE.shopUrl} rel="noopener">
        Buy Merch
      </a>
      <a class="btn btn--ticket" href="/tickets/">Get Tickets</a>

      <button
        type="button"
        class="site-header__menu-btn"
        aria-expanded="false"
        aria-controls="primary-nav"
        data-menu-toggle
      >
        <span aria-hidden="true" data-menu-icon>☰</span>
        Menu
      </button>
    </div>
  </div>
</header>

<style>
  .site-header {
    background: var(--color-bg);
    border-bottom: 2px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .site-header__inner {
    max-width: 72rem;
    margin-inline: auto;
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: nowrap;   /* single row on desktop; wraps on mobile (below) */
  }
  .site-header__brand {
    font-weight: 800;
    font-size: 1.25rem;
    color: var(--color-text);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    min-height: 44px;
  }
  .site-header__logo { height: 48px; width: auto; }
  .site-header__logo--hc { display: none; }
  :global(html[data-a11y-contrast='high']) .site-header__logo--color { display: none; }
  :global(html[data-a11y-contrast='high']) .site-header__logo--hc { display: inline; }

  /* Right-hand action cluster: Buy Merch + Get Tickets (+ mobile toggle) */
  .site-header__actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-left: auto;
  }
  .site-header__actions .btn { padding: 0.5rem 1.15rem; }

  .site-header__menu-btn {
    display: none;
    align-items: center;
    gap: 0.5rem;
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    border-radius: 8px;
    padding: 0.5rem 0.9rem;
    font-weight: 600;
    color: var(--color-text);
    min-height: 44px;
  }
  .site-header__nav ul {
    display: flex;
    gap: 0.1rem;
    list-style: none;
    margin: 0;
    padding: 0;
    flex-wrap: nowrap;   /* stay one line on desktop */
  }
  .site-header__nav a {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 0.6rem;
    color: var(--color-text);
    text-decoration: none;
    font-weight: 600;
    border-radius: 8px;
    white-space: nowrap;
  }
  .site-header__nav a:hover { background: var(--color-surface); }
  /* Active page: bold + underline + aria-current (not color alone) */
  .site-header__nav a[aria-current='page'] {
    text-decoration: underline;
    text-underline-offset: 0.3em;
    text-decoration-thickness: 2px;
    color: var(--color-accent);
  }

  @media (max-width: 66rem) {
    .site-header__inner { flex-wrap: wrap; }
    .site-header__menu-btn { display: inline-flex; }
    .site-header__nav { display: none; width: 100%; order: 3; }
    .site-header__nav.is-open { display: block; }
    .site-header__nav ul { flex-direction: column; }
    .site-header__nav a { width: 100%; }
    /* On small screens the shop is reachable via the Merch nav link */
    .site-header__buy { display: none; }
  }
  @media (max-width: 26rem) {
    .site-header__actions .btn--secondary,
    .site-header__actions .btn--ticket { padding: 0.5rem 0.9rem; }
  }
</style>

<script>
  const btn = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
  const nav = document.querySelector<HTMLElement>('[data-menu]');
  if (btn && nav) {
    btn.addEventListener('click', () => {
      const open = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!open));
      nav.classList.toggle('is-open', !open);
    });
    // Close on Escape, return focus to button
    nav.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && nav.classList.contains('is-open')) {
        nav.classList.remove('is-open');
        btn.setAttribute('aria-expanded', 'false');
        btn.focus();
      }
    });
  }
</script>
