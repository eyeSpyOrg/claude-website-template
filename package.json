{
  "name": "a11y-web-foundation",
  "version": "1.0.0",
  "description": "Accessibility-first, SEO/AEO-optimized website foundation. WCAG 2.2 AA baseline, WAVE/Lighthouse 90+ target.",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "test:a11y": "pa11y-ci --config tests/pa11yci.json",
    "test:lighthouse": "lhci autorun --config=tests/lighthouserc.json",
    "test": "npm run build && npm run test:html && npm run test:a11y",
    "test:html": "html-validate \"dist/**/*.html\""
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.2.1",
    "astro": "^5.1.0"
  },
  "devDependencies": {
    "@lhci/cli": "^0.14.0",
    "@tailwindcss/vite": "^4.0.0",
    "html-validate": "^11.5.0",
    "pa11y-ci": "^3.1.0",
    "tailwindcss": "^4.0.0"
  }
}
